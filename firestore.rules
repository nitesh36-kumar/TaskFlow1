rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. GLOBAL SAFETY NET
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().get('role', 'Member') == 'Admin') ||
        request.auth.token.email == 'nitesh.kumar@ethara.ai'
      );
    }

    function isApproved() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().get('status', 'Pending') == 'Approved') || 
        isAdmin()
      );
    }

    function isMemberOfProject(projectId) {
      return isApproved() && (
        get(/databases/$(database)/documents/projects/$(projectId)).data.members.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATIONS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['Admin', 'Member'] &&
             data.status in ['Approved', 'Pending'] &&
             data.email is string && data.email.size() <= 256;
    }

    function isOwnProfile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return isApproved() &&
             data.keys().hasAll(['name', 'ownerId', 'members', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.members is list && data.members.size() <= 50;
    }

    function isValidTask(data) {
      return isApproved() &&
             data.keys().hasAll(['projectId', 'title', 'status', 'creatorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['To Do', 'In Progress', 'Review', 'Completed'] &&
             data.projectId is string &&
             data.creatorId == request.auth.uid &&
             (data.keys().contains('assignedTo') ? data.assignedTo is list : true);
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isSignedIn() && (
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])) ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'jobTitle', 'department', 'updatedAt']) && 
         (!request.resource.data.keys().contains('updatedAt') || request.resource.data.updatedAt == request.time))
      );
    }

    match /projects/{projectId} {
      allow get: if isApproved() && (resource.data.ownerId == request.auth.uid || resource.data.members.hasAny([request.auth.uid]));
      allow list: if isApproved() && (resource.data.ownerId == request.auth.uid || resource.data.members.hasAny([request.auth.uid]));
      allow create: if isAdmin() && isValidProject(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isApproved() && (
        // Owners and Admins can update
        ((resource.data.ownerId == request.auth.uid || isAdmin()) && isValidProject(request.resource.data)) ||
        // Allow users to join themselves if they are adding ONLY their own UID to the members list
        // (Note: This is a bit loose but necessary without a complex invitation verification in rules)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && 
         request.resource.data.members.hasAll(resource.data.members) &&
         request.resource.data.members.hasAny([request.auth.uid]) &&
         request.resource.data.members.size() == resource.data.members.size() + 1)
      );
      allow delete: if (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /tasks/{taskId} {
      allow get: if isApproved() && isMemberOfProject(resource.data.projectId);
      allow list: if isApproved() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.get('assignedTo', []).hasAny([request.auth.uid]) ||
        isMemberOfProject(resource.data.projectId)
      );
      allow create: if (isAdmin() || isMemberOfProject(request.resource.data.projectId)) && isValidTask(request.resource.data);
      allow update: if isMemberOfProject(resource.data.projectId) && (
        // Owners/Admins can edit everything
        (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid || isAdmin()) ||
        // Members can only update status if assigned
        (resource.data.get('assignedTo', []).hasAny([request.auth.uid]) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'description']))
      );
      allow delete: if isAdmin() || 
                     resource.data.creatorId == request.auth.uid ||
                     get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid;
    }

    match /invitations/{inviteId} {
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid
      );
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn() && 
        get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && (
        isAdmin() ||
        resource.data.email == request.auth.token.email ||
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid
      );
    }
  }
}
